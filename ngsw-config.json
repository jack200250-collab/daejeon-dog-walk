{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/icons/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "spot-images",
      "urls": ["https://images.unsplash.com/**"],
      "cacheConfig": {
        "maxSize": 30,
        "maxAge": "7d",
        "strategy": "performance"
      }
    }
  ]
}
